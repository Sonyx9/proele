---
import "../styles/global.css";

const topNav = [
  { label: "Služby", href: "#section-a" },
  { label: "Požární ucpávky", href: "#pozarni-ucpavky" },
  { label: "Proč my", href: "#proc-my" },
  { label: "Reference", href: "#reference" },
  { label: "Partneři", href: "#partneri" },
  { label: "FAQ", href: "#faq" },
  { label: "Kontakt", href: "#kontakt" },
];

const ucpavkyHighlights = [
  {
    title: "Zabrání rychlému šíření požáru",
    text: "Díky tomu je více času na evakuaci a příjezd hasičů."
  },
  {
    title: "Zamezí průniku škodlivých plynů",
    text: "Kouř bývá často nebezpečnější než samotný oheň."
  },
  {
    title: "Udrží stabilitu budovy déle",
    text: "Konstrukce odolá vyšším teplotám po nezbytně nutnou dobu."
  }
];

const ucpavkyReasons = [
  {
    title: "Rozdělení budovy na požární úseky",
    text: "Budovy jsou projektovány tak, aby byly rozděleny do menších celků (požárních úseků). Pokud v jednom úseku začne hořet, ucpávky zajistí, aby se oheň nepřelil do sousedních místností nebo pater po dobu desítek minut (např. 30, 60 nebo 90 minut).",
    accent: "Cíl: Udržet požár „v jedné krabici“."
  },
  {
    title: "Ochrana únikových cest",
    text: "Největším zabijákem při požáru není žár, ale kouř a toxické zplodiny. Instalace ucpávek brání pronikání kouře do chodeb a schodišť, kudy musí lidé bezpečně utéct. Bez těsnění se kouř šíří šachtami a prostupy rychlostí blesku."
  },
  {
    title: "Ochrana nosné konstrukce",
    text: "Požární ucpávky pomáhají udržet stabilitu budovy. Zabraňují tomu, aby horké plyny oslabily nosné konstrukce v místech, kde jimi prochází instalace, což by mohlo vést k předčasnému zřícení objektu."
  },
  {
    title: "Zákonné a normové požadavky",
    text: "V České republice je realizace ucpávek povinností vyplývající z legislativy (např. vyhláška o technických podmínkách požární ochrany staveb)."
  }
];

const infoCards = [
  {
    title: "Kompletní realizace",
    text: "Jeden tým od prvního výkresu až po předání revizní dokumentace. Nemusíte koordinovat více dodavatelů – vše řídíme za vás, v termínu a s plnou zodpovědností.",
    icon: "clipboard"
  },
  {
    title: "Požární bezpečnost",
    text: "Projektujeme, instalujeme a pravidelně revidujeme požárně bezpečnostní systémy (EPS, SHZ, pasivní PO) v souladu s normami ČSN. Jsme certifikovaní specialisté Hilti.",
    icon: "shield"
  }
];

const transformCards = [
  {
    title: "Bytové domy a SVJ",
    text: "Kompletní elektroinstalace, výměna stoupacích vedení a modernizace společných prostor panelových domů.",
    image: "reference-bytovy-dum.webp",
    alt: "Moderní bytový dům s balkony a zelenými stromy na ulici v podvečerním světle. Architektonická elegance a městské bydlení.",
    title_attr: "Moderní bytový dům ve městě"
  },
  {
    title: "Komerční objekty",
    text: "Slaboproudé systémy, kamerové systémy CCTV, přístupové systémy a strukturovaná kabeláž pro firemní budovy.",
    image: "reference-komercni.webp",
    alt: "Moderní kancelářská budova s prosklenou fasádou při západu slunce",
    title_attr: "Moderní kancelářská budova při západu slunce"
  },
  {
    title: "Průmyslové provozy",
    text: "Silnoproudé elektroinstalace, rozvaděče a požárně bezpečnostní řešení pro výrobní a skladové objekty.",
    image: "reference-prumysl.webp",
    alt: "Moderní průmyslová hala s vysokými regály plnými zboží a osvětlením",
    title_attr: "Moderní skladové prostory s vysokými regály"
  }
];

const styleMiniCards = [
  "Nezávazná poptávka zdarma",
  "Certifikovaný tým specialistů",
  "Termíny, které dodržujeme"
];

const assetPrefix = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const heroImageUrl = `${assetPrefix}hero-elektrikar.webp`;
const logoUrl = `${assetPrefix}logo.svg`;
const faviconUrl = `${assetPrefix}favicon.svg`;
const partnerHiltiUrl = `${assetPrefix}partner-hilti.svg`;
const partnerDunamentiUrl = `${assetPrefix}partner-dunamenti.png`;

const faqSections = [
  {
    title: "Revize a legislativa",
    items: [
      {
        question: "Jak často se musí provádět revize elektroinstalace?",
        answer:
          "Lhůty se liší podle typu objektu, prostředí a počtu osob v budově. U administrativních budov je standardní lhůta 5 let, u objektů, kde se trvale pohybuje více než 200 osob, je lhůta 2 roky. U prostor s rizikem výbuchu nebo ve venkovním prostředí jsou lhůty kratší. Rádi vám doporučíme správný interval pro váš objekt."
      },
      {
        question: "Jsou vaše práce v souladu s aktuálními normami ČSN?",
        answer:
          "Ano, veškeré naše montáže a projekty odpovídají platným normám ČSN. Po dokončení každé zakázky obdržíte řádnou revizní zprávu podepsanou oprávněným revizním technikem."
      },
      {
        question: "Zpracujete cenovou nabídku zdarma?",
        answer:
          "Ano, na základě vaší poptávky nebo prohlídky objektu připravíme nezávaznou kalkulaci na míru – bez závazků a zcela zdarma. Odpovíme do 48 hodin od přijetí poptávky."
      }
    ]
  },
  {
    title: "Elektromontáže a slaboproud",
    items: [
      {
        question: "Provádíte kompletní rekonstrukce v panelových domech pro SVJ?",
        answer:
          "Ano, specializujeme se na výměnu stoupacích vedení (HDV), rekonstrukci společných prostor i modernizaci osvětlení s využitím úsporných LED technologií. Máme zkušenosti s koordinací prací v obydlených budovách."
      },
      {
        question: "Lze propojit kamerový systém s mobilním telefonem?",
        answer:
          "Samozřejmě. Moderní zabezpečovací a kamerové systémy (CCTV), které instalujeme, umožňují vzdálený přístup přes mobilní aplikaci – máte přehled o objektu 24 hodin denně, 7 dní v týdnu."
      }
    ]
  },
  {
    title: "Požární bezpečnost",
    items: [
      {
        question: "Musí být v každém bytovém domě instalována EPS?",
        answer:
          "Povinnost vychází z požárně bezpečnostního řešení stavby (projektové dokumentace). U novostaveb a větších rekonstrukcí je elektronická požární signalizace již standardem. Rádi vám bezplatně posoudíme, jaké požadavky se na váš objekt vztahují."
      },
      {
        question: "Zajišťujete i následný servis a funkční zkoušky požárních systémů?",
        answer:
          "Ano, instalací to pro nás nekončí. Provádíme pravidelné roční kontroly provozuschopnosti a servis všech požárně bezpečnostních zařízení – jsme certifikovaní specialisté na systémy pasivní požární ochrany Hilti."
      }
    ]
  }
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PROELLE | Elektromontáže a požární bezpečnost</title>
    <meta name="description" content="Komplexní elektroinstalace a požární bezpečnost pro bytová družstva, SVJ, developery i průmyslové provozy. Certifikovaní specialisté Hilti. Praha a okolí." />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
  </head>
  <body class="bg-[#efefef] text-black antialiased">

    <!-- ===== FIXNÍ HEADER ===== -->
    <header id="site-header" class="site-header fixed inset-x-0 top-0 z-50">
      <div class="page-gutter flex items-center justify-between py-3 md:py-4">
        <a href="#hero" class="inline-flex items-center" aria-label="PROELLE – domů">
          <img src={logoUrl} alt="PROELLE" class="site-logo h-8 w-auto md:h-10" />
        </a>
        <div class="flex items-center gap-2 sm:gap-3">
          <a href="#kontakt" class="btn-brand inline-flex h-12 items-center rounded-lg px-4 text-sm font-semibold shadow-lg sm:px-5 md:h-14 md:px-6">Zavolat</a>
          <a href="#kontakt" class="hidden h-12 items-center rounded-lg border border-white/25 bg-black/50 px-4 text-sm font-semibold text-white shadow-lg backdrop-blur hover:bg-white hover:text-black sm:inline-flex sm:px-5 md:h-14 md:px-6">Napsat</a>
          <details class="relative">
            <summary class="flex h-12 w-12 cursor-pointer list-none items-center justify-center rounded-lg border border-white/30 bg-black/30 text-white backdrop-blur md:h-14 md:w-14">
              <span class="sr-only">Menu</span>
              <svg viewBox="0 0 24 24" class="h-7 w-7 fill-none stroke-current md:h-8 md:w-8" stroke-width="2" aria-hidden="true">
                <path d="M5 9h14M5 15h9" stroke-linecap="round"></path>
              </svg>
            </summary>
            <div class="absolute right-0 mt-3 w-72 rounded-2xl border border-white/20 bg-black/85 p-3 text-white shadow-xl backdrop-blur md:w-80">
              <ul class="space-y-1">
                <li class="sm:hidden">
                  <a href="#kontakt" class="block rounded-lg px-4 py-3 text-base font-medium hover:bg-white hover:text-black">Napsat</a>
                </li>
                {topNav.map((item) => (
                  <li>
                    <a href={item.href} class="block rounded-lg px-4 py-3 text-base font-medium hover:bg-white hover:text-black">{item.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        </div>
      </div>
    </header>

    <main class="space-y-8 pb-6 md:space-y-10">

      <!-- ===== HERO ===== -->
      <section
        id="hero"
        class="hero-shell relative min-h-[95vh] overflow-hidden bg-cover bg-center"
      >
        <img
          src={heroImageUrl}
          alt="Elektrikář v modré montérce kontroluje elektrickou rozvodnou skříň v bytovém domě pomocí měřicího přístroje a nářadí."
          title="Elektrikář pracuje s rozvodnou skříní v domě"
          class="absolute inset-0 h-full w-full object-cover object-right"
          loading="eager"
          decoding="async"
        />
        <div class="hero-overlay-strong absolute inset-0"></div>

        <div class="page-gutter relative z-10 flex min-h-[95vh] flex-col pt-7">

          <!-- Hero obsah -->
          <div class="flex flex-1 items-center pt-20 md:pt-28">
            <div class="max-w-5xl">
              <p class="text-xl font-medium text-white/90 sm:text-2xl md:text-[28px]">Od projektu po revizi. Jeden tým, jedna odpovědnost.</p>
              <h1 class="hero-display mt-3 max-w-4xl text-4xl font-extrabold leading-[1.05] text-white sm:text-5xl md:text-7xl md:leading-[1.02]">
                Komplexní elektro<br />a požární bezpečnost
              </h1>
              <a
                href="#section-a"
                class="group mx-auto mt-14 inline-flex items-center gap-3 rounded-xl bg-white px-6 py-3 text-lg font-semibold text-black transition hover:-translate-y-0.5 hover:shadow-lg"
              >
                Naše služby
                <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current transition-transform duration-200 group-hover:translate-x-1" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Kontaktní box vpravo dole -->
          <div class="mt-auto mb-6 flex items-end justify-end">
            <a
              href="#kontakt"
              class="group hidden max-w-[20rem] rounded-3xl border border-white/20 bg-black/35 p-4 text-white backdrop-blur transition hover:bg-white hover:text-black md:block"
            >
              <p class="text-xs font-medium uppercase tracking-wide text-white/80 transition group-hover:text-black/70">Kontakt</p>
              <p class="mt-1 text-2xl font-semibold leading-tight">Nezávazná konzultace</p>
              <p class="mt-2 text-sm text-white/85 transition group-hover:text-black/80">Prohlídka objektu, návrh řešení a cenová nabídka – vše zdarma a do 48 hodin.</p>
            </a>
          </div>
        </div>
      </section>

      <!-- ===== SLUŽBY ===== -->
      <section id="section-a" class="px-4 md:px-6">
        <div class="page-gutter">
          <p class="section-eyebrow">Naše odbornost</p>
          <h2 class="text-center text-2xl font-extrabold leading-[1.15] md:text-4xl">Elektro a požární bezpečnost<br />bez kompromisů</h2>
          <p class="mx-auto mt-4 max-w-4xl text-center text-sm leading-relaxed text-neutral-700 md:text-base">
            Zakládáme si na individuálním přístupu a plné odpovědnosti za každou zakázku. Dlouhodobě spolupracujeme s bytovými družstvy, společenstvími vlastníků (SVJ), developery, stavebními firmami i soukromými investory.
          </p>

          <div class="mt-8 grid items-stretch gap-4 lg:grid-cols-3">
            <!-- Hlavní karta – červená -->
            <article class="relative flex min-h-[360px] flex-col justify-between gap-6 overflow-hidden rounded-3xl bg-[linear-gradient(155deg,#D50101_0%,#B40000_45%,#7F0000_100%)] p-6 text-white">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/60 bg-white/10">
                <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current text-white" stroke-width="1.8" aria-hidden="true">
                  <path d="M13 2 6 13h5l-1 9 8-12h-5l0-8Z" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
              <div>
                <h3 class="max-w-[14rem] text-[34px] font-semibold leading-[1.02]">Silnoproud a slaboproud</h3>
                <p class="mt-4 max-w-[18rem] text-sm leading-relaxed text-white/90">
                  Kompletní elektroinstalace bytových domů, komerčních i průmyslových objektů. Nová zapojení, rekonstrukce i modernizace osvětlení na úsporné LED.
                </p>
              </div>
              <a
                href="#kontakt"
                class="group inline-flex w-fit items-center gap-2 rounded-lg bg-white px-4 py-2 text-sm font-semibold text-black transition hover:-translate-y-0.5 hover:shadow-lg"
              >
                Nezávazná poptávka <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
              </a>
            </article>

            <!-- Světlé karty -->
            {infoCards.map((card) => (
              <article class="flex h-full flex-col rounded-3xl bg-[#e6e6eb] p-6">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white">
                  {card.icon === "clipboard" ? (
                    <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current text-black" stroke-width="1.8" aria-hidden="true">
                      <path d="M9 4h6m-5 0a1 1 0 0 0-1 1v1h6V5a1 1 0 0 0-1-1m-8 3h12a1 1 0 0 1 1 1v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V8a1 1 0 0 1 1-1Z" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current text-black" stroke-width="1.8" aria-hidden="true">
                      <path d="M12 3 5 6v5c0 4.4 3 8.5 7 10 4-1.5 7-5.6 7-10V6l-7-3Z" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  )}
                </span>
                <h3 class="mt-5 max-w-[14rem] text-[36px] font-semibold leading-[1.03]">{card.title}</h3>
                <p class="mt-7 text-sm leading-relaxed text-neutral-700">{card.text}</p>
                <a
                  href="#kontakt"
                  class="group mt-auto inline-flex w-fit items-center gap-2 rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-neutral-800 hover:shadow-lg"
                >
                  Nezávazná poptávka <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ===== POŽÁRNÍ UCPÁVKY ===== -->
      <section id="pozarni-ucpavky" class="px-4 md:px-6">
        <div class="page-gutter">
          <p class="section-eyebrow">Požární bezpečnost staveb</p>
          <h2 class="text-center text-2xl font-extrabold leading-[1.15] md:text-4xl">Požární ucpávky</h2>
          <p class="mx-auto mt-4 max-w-3xl text-center text-sm leading-relaxed text-neutral-700 md:text-base">
            Realizace požárních ucpávek není jen „úřední šiml“, ale kritický prvek bezpečnosti každé budovy. Pokud byste je vynechali, dům se v případě požáru začne chovat jako dýmka – oheň a jedovatý kouř se budou šířit neřízeně skrze otvory pro kabely a trubky.
          </p>

          <div class="mt-8 grid gap-4 md:grid-cols-3">
            {ucpavkyHighlights.map((card) => (
              <article class="rounded-3xl bg-[#e6e6eb] p-6">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white">
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current text-[#d60000]" stroke-width="1.8" aria-hidden="true">
                    <path d="M12 3c1.5 4 4 5 4 9a4 4 0 0 1-8 0c0-2 1-3 1.5-5C10 8 11 5.5 12 3Z" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </span>
                <h3 class="mt-4 text-lg font-semibold leading-snug">{card.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-neutral-700">{card.text}</p>
              </article>
            ))}
          </div>

          <div class="mt-8 rounded-3xl bg-[#e8e8ec] p-6 md:p-10">
            <p class="max-w-3xl text-sm leading-relaxed text-neutral-700 md:text-base">
              Zde jsou hlavní důvody, proč jsou ucpávky nezbytné:
            </p>
            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {ucpavkyReasons.map((item, idx) => (
                <article class="rounded-2xl bg-white p-5 shadow-soft md:p-6">
                  <div class="flex items-start gap-3">
                    <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#d60000] text-sm font-semibold text-white">{idx + 1}</span>
                    <h3 class="text-lg font-semibold leading-snug">{item.title}</h3>
                  </div>
                  <p class="mt-3 text-sm leading-relaxed text-neutral-700">{item.text}</p>
                  {item.accent && (
                    <p class="mt-3 text-sm font-semibold text-[#d60000]">{item.accent}</p>
                  )}
                </article>
              ))}
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-2">
              <article class="rounded-2xl bg-white p-5 shadow-soft md:p-6">
                <div class="flex items-start gap-3">
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#d60000] text-sm font-semibold text-white">5</span>
                  <h3 class="text-lg font-semibold leading-snug">Kolaudace</h3>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-neutral-700">
                  Bez revizní zprávy a řádného označení ucpávek štítky budovu legálně nezkolaudujete.
                </p>
              </article>
              <article class="rounded-2xl bg-white p-5 shadow-soft md:p-6">
                <div class="flex items-start gap-3">
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#d60000] text-sm font-semibold text-white">6</span>
                  <h3 class="text-lg font-semibold leading-snug">Pojišťovny</h3>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-neutral-700">
                  Pokud dojde k požáru a zjistí se, že ucpávky chyběly nebo byly neodborně provedeny, pojišťovna pravděpodobně krátí nebo zcela odmítne pojistné plnění.
                </p>
              </article>
            </div>
          </div>

          <div class="mt-8 text-center">
            <a
              href="#kontakt"
              class="btn-brand inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold"
            >
              Poptat realizaci požárních ucpávek
              <span>→</span>
            </a>
          </div>
        </div>
      </section>

      <!-- ===== PROČ MY ===== -->
      <section id="proc-my" class="px-4 md:px-6">
        <div class="page-gutter grid gap-4 rounded-3xl lg:grid-cols-[1fr_1.35fr]">
          <article class="rounded-3xl bg-[#e6e6eb] p-8 md:p-12">
            <p class="section-eyebrow !text-left !mb-4">Proč si vybrat nás</p>
            <h2 class="text-3xl font-extrabold leading-[1.1] sm:text-5xl md:text-7xl md:leading-[1.02]">Zkušenosti,<br />které mluví<br />za výsledky</h2>
            <p class="mt-6 max-w-xl text-base leading-relaxed text-neutral-700">
              Každý projekt řešíme individuálně. Přijdeme, posoudíme situaci, navrhneme optimální řešení a celou realizaci dotáhneme do konce – včas a s veškerou dokumentací.
            </p>
            <ul class="mt-8 space-y-3 text-sm font-semibold">
              <li class="flex items-center gap-2">
                <span class="check-brand inline-flex h-5 w-5 items-center justify-center rounded-full text-[10px]">✓</span>
